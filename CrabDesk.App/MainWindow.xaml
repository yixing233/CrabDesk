                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="桌面盒子" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="管理盒子名称和显示顺序" Style="{StaticResource PageSubtitleStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Button Width="126" Height="38" Margin="0,0,10,0"
                                    Click="AddMappedFolderButton_OnClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons" FontSize="14" Margin="0,0,7,0" />
                                    <TextBlock Text="映射文件夹" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Width="120" Height="38"
                                    Click="AddBoxButton_OnClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="14" Margin="0,0,7,0" />
                                    <TextBlock Text="新建盒子" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{DynamicResource SurfaceBackground}"
                                BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                                CornerRadius="8" Padding="8">
                            <ListBox x:Name="BoxesList" AutomationProperties.Name="盒子列表"
                                     AutomationProperties.AutomationId="BoxesList"
                                     SelectionChanged="BoxesList_OnSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="4" CornerRadius="2" Background="{DynamicResource AccentBrush}" />
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="11" Foreground="{DynamicResource MutedTextBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="桌面分组" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMappedFolder}" Value="True">
                                                                    <Setter Property="Text" Value="文件夹映射" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="盒子名称" Style="{StaticResource SectionTitleStyle}" />
                            <TextBox x:Name="BoxTitleTextBox" AutomationProperties.Name="盒子名称"
                                     AutomationProperties.AutomationId="BoxTitleTextBox"
                                     LostFocus="BoxTitleTextBox_OnLostFocus" />
                            <StackPanel x:Name="MappedFolderPanel" Margin="0,22,0,0" Visibility="Collapsed">
                                <TextBlock Text="映射位置" Style="{StaticResource SectionTitleStyle}" />
                                <Border Background="{DynamicResource SurfaceBackground}"
                                        BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                                        CornerRadius="7" Padding="12,9">
                                    <TextBlock x:Name="MappedFolderPathText" TextWrapping="Wrap"
                                               FontSize="12" Foreground="{DynamicResource MutedTextBrush}" />
                                </Border>
                                <TextBlock x:Name="MappedFolderStatusText" Margin="2,7,0,0" FontSize="12"
                                           Foreground="{DynamicResource MutedTextBrush}" />
                                <Grid Margin="0,14,0,0">
                                    <Button Content="更改文件夹" Width="108" HorizontalAlignment="Left"
                                            Click="ChangeMappedFolderButton_OnClick" />
                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="只读" Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <CheckBox x:Name="MappedFolderReadOnlyCheckBox"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Checked="MappedFolderReadOnlyCheckBox_OnChanged"
                                                  Unchecked="MappedFolderReadOnlyCheckBox_OnChanged" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                            <Border BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="0,0,0,1" Margin="0,22,0,18" />
                            <Button Content="删除盒子" Style="{StaticResource DangerButtonStyle}"
                                    AutomationProperties.AutomationId="DeleteBoxButton"
                                    Click="DeleteBoxButton_OnClick" HorizontalAlignment="Left" Width="112" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Style="{StaticResource NavTabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE946;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="28" />
                        <TextBlock Text="关于" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer x:Name="AboutScrollViewer" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="44,36,48,38" MaxWidth="660">
                        <TextBlock Text="关于" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="版本、更新和本地数据" Style="{StaticResource PageSubtitleStyle}" />

                        <StackPanel Orientation="Horizontal" Margin="0,36,0,30">
                            <Image Source="Assets/CrabDesk-256.png" Width="72" Height="72" Margin="0,0,20,0" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="CrabDesk" FontFamily="{x:Static SystemFonts.MessageFontFamily}"
                                           FontSize="27" FontWeight="SemiBold" />
                                <TextBlock x:Name="AppVersionText" Foreground="{DynamicResource MutedTextBrush}" Margin="0,5,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="检查更新" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                            <Button x:Name="CheckForUpdatesButton" HorizontalAlignment="Right" Width="112" Height="36"
                                    Click="CheckForUpdatesButton_OnClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="14" Margin="0,0,7,0" />
                                    <TextBlock Text="检查更新" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Border Style="{StaticResource SettingRowStyle}">
                            <Grid>
                                <TextBlock Text="启动时检查更新" VerticalAlignment="Center" />
                                <CheckBox x:Name="CheckUpdatesOnStartupCheckBox" Style="{StaticResource ToggleSwitchStyle}"
                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Checked="CheckUpdatesOnStartupCheckBox_OnChanged"
                                          Unchecked="CheckUpdatesOnStartupCheckBox_OnChanged" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SettingRowStyle}" MinHeight="68">
                            <Grid>
                                <TextBlock Text="发布通道" VerticalAlignment="Center" />
                                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Padding="3"
                                        CornerRadius="7" Background="{DynamicResource ControlBackground}"
                                        BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="StableUpdateChannelRadioButton" Content="稳定版" Tag="Stable"
                                                     GroupName="UpdateChannel" Style="{StaticResource SegmentRadioStyle}"
                                                     Checked="UpdateChannelRadioButton_OnChecked" />
                                        <RadioButton x:Name="PreviewUpdateChannelRadioButton" Content="测试版" Tag="Preview"
                                                     GroupName="UpdateChannel" Style="{StaticResource SegmentRadioStyle}"
                                                     Checked="UpdateChannelRadioButton_OnChecked" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SettingRowStyle}" MinHeight="72">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="GitHub Releases" />
                                    <TextBlock x:Name="UpdateRepositoryText" Margin="0,4,0,0" FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </StackPanel>
                                <TextBlock x:Name="LastUpdateCheckText" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           FontSize="12" Foreground="{DynamicResource MutedTextBrush}" />
                            </Grid>
                        </Border>
                        <Grid Margin="0,14,0,26">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock x:Name="UpdateStatusText" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock x:Name="UpdateReleaseNameText" Margin="0,5,0,0" TextWrapping="Wrap"
                                           Foreground="{DynamicResource MutedTextBrush}" />
                            </StackPanel>
                            <Button x:Name="OpenReleasePageButton" Grid.Column="1" Content="查看发布页" Width="104"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Visibility="Collapsed" Click="OpenReleasePageButton_OnClick" />
                        </Grid>
                        <Border x:Name="ReleaseNotesBorder" Visibility="Collapsed"
                                Background="{DynamicResource SurfaceBackground}"
                                BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                                CornerRadius="7" Padding="14,11" Margin="0,-12,0,26" MaxHeight="150">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="ReleaseNotesText" TextWrapping="Wrap" FontSize="12" />
                            </ScrollViewer>
                        </Border>

                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="配置目录" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                            <Button HorizontalAlignment="Right" Width="104" Height="34"
                                    Click="OpenConfigDirectoryButton_OnClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE838;" FontFamily="Segoe Fluent Icons" FontSize="14" Margin="0,0,7,0" />
                                    <TextBlock Text="打开目录" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Border Background="{DynamicResource SurfaceBackground}"
                                BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                                CornerRadius="7" Padding="14,12">
                            <TextBlock x:Name="ConfigPathText" TextWrapping="Wrap"
                                       FontFamily="{x:Static SystemFonts.MessageFontFamily}" FontSize="12"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Border>
                        <Border Style="{StaticResource SettingRowStyle}" Margin="0,14,0,0" MinHeight="68">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="图标与缩略图缓存" />
                                    <TextBlock x:Name="ThumbnailCacheStatusText" Text="用于加快桌面盒子绘制"
                                               Margin="0,4,0,0" FontSize="12"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="清理缓存" Width="92"
                                        VerticalAlignment="Center" Click="ClearThumbnailCacheButton_OnClick" />
                            </Grid>
                        </Border>

                        <TextBlock Text="桌面宿主诊断" Style="{StaticResource SectionTitleStyle}" Margin="0,28,0,10" />
                        <Border Background="{DynamicResource SurfaceBackground}"
                                BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                                CornerRadius="7" Padding="14,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="DiagnosticsStatusText" FontWeight="SemiBold" />
                                <TextBlock x:Name="DiagnosticsHostText" Grid.Row="1" Margin="0,5,0,0" FontSize="12"
                                           TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" />
                                <TextBlock x:Name="DiagnosticsTopologyText" Grid.Row="2" Margin="0,3,0,0" FontSize="12"
                                           TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" />
                            </Grid>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Width="104" Margin="0,0,10,0" Click="CopyDiagnosticsButton_OnClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons" FontSize="14" Margin="0,0,7,0" />
                                    <TextBlock Text="复制诊断" />
                                </StackPanel>
                            </Button>
                            <Button Width="104" Click="ReconnectButton_OnClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="14" Margin="0,0,7,0" />
                                    <TextBlock Text="重新连接" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock Text="维护" Style="{StaticResource SectionTitleStyle}" Margin="0,28,0,10" />
                        <Border Style="{StaticResource SettingRowStyle}" MinHeight="76">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="重置桌面布局" />
                                    <TextBlock Text="重建默认盒子，当前布局会先自动备份" Margin="0,4,0,0" FontSize="12"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="重置布局" Width="92" VerticalAlignment="Center"
                                        Style="{StaticResource DangerButtonStyle}" Click="ResetLayoutButton_OnClick" />
                            </Grid>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <Button Content="隐私说明" Width="92" Margin="0,0,10,0"
                                    Click="PrivacyButton_OnClick" />
                            <Button Content="开源许可" Width="92" Click="LicenseButton_OnClick" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Grid Width="208" HorizontalAlignment="Left" IsHitTestVisible="False">
            <StackPanel Margin="20,24,16,0" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <Image Source="Assets/CrabDesk-256.png" Width="36" Height="36" Margin="0,0,11,0" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="CrabDesk" FontFamily="{x:Static SystemFonts.MessageFontFamily}"
                                   FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                        <TextBlock Text="桌面整理" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <TextBlock x:Name="SidebarVersionText" Margin="20,0,0,24" VerticalAlignment="Bottom"
                       FontSize="11" Foreground="{DynamicResource MutedTextBrush}" />
        </Grid>
    </Grid>
</Window>
