<Window x:Class="CrabDesk.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CrabDesk 设置"
        Width="920"
        Height="640"
        MinWidth="820"
        MinHeight="560"
        Background="{DynamicResource WindowBackground}"
        Icon="Assets/CrabDesk.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate x:Key="HotkeyOptionTemplate">
            <TextBlock Text="{Binding Label}" />
        </DataTemplate>
        <Style x:Key="NavTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Height="44">
                            <Border x:Name="Selection" CornerRadius="6" Background="Transparent" />
                            <Border x:Name="Indicator" Width="3" Height="20" CornerRadius="2"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Background="{DynamicResource AccentBrush}" Visibility="Collapsed" />
                            <ContentPresenter ContentSource="Header" Margin="16,0,12,0" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Selection" Property="Background" Value="{DynamicResource ControlBackground}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Selection" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingRowStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="62" />
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorder}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="RuleGridItemStyle" TargetType="ListBoxItem">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorder}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Row" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="{DynamicResource ControlBackground}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RuleToolButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,3,0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonSurface" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="{DynamicResource ControlBackground}" />
                                <Setter TargetName="ButtonSurface" Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                <Setter Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RuleHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl x:Name="SettingsTabs" TabStripPlacement="Left" BorderThickness="0" Background="Transparent">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="208" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource PanelBackground}"
                                BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="0,0,1,0" />
                        <TabPanel Grid.Column="0" IsItemsHost="True" Margin="12,104,12,72" />
                        <Border Grid.Column="1" Background="{DynamicResource WindowBackground}">
                            <ContentPresenter ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>

            <TabItem Style="{StaticResource NavTabItemStyle}" AutomationProperties.Name="常规">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE80F;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="28" />
                        <TextBlock Text="常规" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer x:Name="GeneralScrollViewer" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="44,36,48,38" MaxWidth="700">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="常规" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="桌面接管、启动和外观" Style="{StaticResource PageSubtitleStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,34,0,0">
                            <TextBlock Text="桌面" Style="{StaticResource SectionTitleStyle}" />
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border x:Name="StatusIndicator" Width="8" Height="8" CornerRadius="4" Margin="0,0,10,0"
                                                Background="{DynamicResource SuccessBrush}" />
                                        <TextBlock x:Name="StatusText" Text="桌面已连接" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button x:Name="PauseButton" Grid.Column="1" Content="暂停接管"
                                            Width="104" VerticalAlignment="Center" Click="PauseButton_OnClick" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Explorer 桌面连接" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Width="104" VerticalAlignment="Center" Click="ReconnectButton_OnClick">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="14" Margin="0,0,7,0" />
                                            <TextBlock Text="重新连接" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="0,30,0,0">
                            <TextBlock Text="偏好" Style="{StaticResource SectionTitleStyle}" />
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <TextBlock Text="登录 Windows 后启动" VerticalAlignment="Center" />
                                    <CheckBox x:Name="StartupCheckBox" Style="{StaticResource ToggleSwitchStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="StartupCheckBox_OnChanged" Unchecked="StartupCheckBox_OnChanged" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <TextBlock Text="删除盒子前确认" VerticalAlignment="Center" />
                                    <CheckBox x:Name="ConfirmDeleteCheckBox" Style="{StaticResource ToggleSwitchStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="ConfirmDeleteCheckBox_OnChanged" Unchecked="ConfirmDeleteCheckBox_OnChanged" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <TextBlock Text="启动后仅驻留托盘" VerticalAlignment="Center" />
                                    <CheckBox x:Name="LaunchToTrayCheckBox" Style="{StaticResource ToggleSwitchStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="LaunchToTrayCheckBox_OnChanged" Unchecked="LaunchToTrayCheckBox_OnChanged" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <TextBlock Text="显示系统桌面项目" VerticalAlignment="Center" />
                                    <CheckBox x:Name="ShowSystemItemsCheckBox" Style="{StaticResource ToggleSwitchStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="ShowSystemItemsCheckBox_OnChanged" Unchecked="ShowSystemItemsCheckBox_OnChanged" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="双击桌面空白处隐藏图标" />
                                        <TextBlock Text="再次双击恢复桌面和盒子中的图标" Margin="0,4,0,0" FontSize="12"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                    </StackPanel>
                                    <CheckBox x:Name="DesktopDoubleClickCheckBox" Style="{StaticResource ToggleSwitchStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="DesktopDoubleClickCheckBox_OnChanged"
                                              Unchecked="DesktopDoubleClickCheckBox_OnChanged" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="桌面右键菜单入口" />
                                        <TextBlock Text="在桌面空白处右键打开 CrabDesk" Margin="0,4,0,0" FontSize="12"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                    </StackPanel>
                                    <CheckBox x:Name="DesktopContextMenuCheckBox" Style="{StaticResource ToggleSwitchStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="DesktopContextMenuCheckBox_OnChanged"
                                              Unchecked="DesktopContextMenuCheckBox_OnChanged" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="悬停展开折叠盒子" />
                                        <TextBlock Text="鼠标离开盒子后恢复折叠状态" Margin="0,4,0,0" FontSize="12"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                    </StackPanel>
                                    <CheckBox x:Name="ExpandBoxOnHoverCheckBox" Style="{StaticResource ToggleSwitchStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="ExpandBoxOnHoverCheckBox_OnChanged"
                                              Unchecked="ExpandBoxOnHoverCheckBox_OnChanged" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="桌面变化后自动刷新" />
                                        <TextBlock Text="重命名、新增或删除项目后更新盒子内容" Margin="0,4,0,0" FontSize="12"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                    </StackPanel>
                                    <CheckBox x:Name="RefreshDesktopItemsCheckBox" Style="{StaticResource ToggleSwitchStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="RefreshDesktopItemsCheckBox_OnChanged"
                                              Unchecked="RefreshDesktopItemsCheckBox_OnChanged" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="界面动画" />
                                        <TextBlock Text="盒子折叠和主题切换使用平滑过渡" Margin="0,4,0,0" FontSize="12"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                    </StackPanel>
                                    <CheckBox x:Name="AnimationEnabledCheckBox" Style="{StaticResource ToggleSwitchStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="AnimationEnabledCheckBox_OnChanged"
                                              Unchecked="AnimationEnabledCheckBox_OnChanged" />
                                </Grid>
                            </Border>
                            <Border MinHeight="68">
                                <Grid>
                                    <TextBlock Text="主题" VerticalAlignment="Center" />
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Padding="3"
                                            CornerRadius="7" Background="{DynamicResource ControlBackground}"
                                            BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton x:Name="SystemThemeRadioButton" Content="跟随系统" Tag="System"
                                                         GroupName="ThemeMode" Style="{StaticResource SegmentRadioStyle}"
                                                         Checked="ThemeModeRadioButton_OnChecked" />
                                            <RadioButton x:Name="LightThemeRadioButton" Content="浅色" Tag="Light"
                                                         GroupName="ThemeMode" Style="{StaticResource SegmentRadioStyle}"
                                                         Checked="ThemeModeRadioButton_OnChecked" />
                                            <RadioButton x:Name="DarkThemeRadioButton" Content="深色" Tag="Dark"
                                                         GroupName="ThemeMode" Style="{StaticResource SegmentRadioStyle}"
                                                         Checked="ThemeModeRadioButton_OnChecked" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource NavTabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE765;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="28" />
                        <TextBlock Text="快捷键" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="44,36,48,38" MaxWidth="760">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="全局快捷键" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="在其他窗口中快速返回桌面或执行整理" Style="{StaticResource PageSubtitleStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <Border Style="{StaticResource SettingRowStyle}" MinHeight="88">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="显示桌面" FontWeight="SemiBold" />
                                    <TextBlock Text="最小化或恢复普通窗口" Margin="0,5,0,0" FontSize="12"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <CheckBox x:Name="ShowDesktopHotkeyEnabledCheckBox"
                                                  Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,16,0"
                                                  Checked="HotkeyControl_OnChanged" Unchecked="HotkeyControl_OnChanged" />
                                        <ComboBox x:Name="ShowDesktopModifiersComboBox" Width="126"
                                                  ItemTemplate="{StaticResource HotkeyOptionTemplate}" SelectedValuePath="Value"
                                                  SelectionChanged="HotkeyControl_OnChanged" />
                                        <TextBlock Text="+" Margin="8,0" VerticalAlignment="Center" />
                                        <ComboBox x:Name="ShowDesktopKeyComboBox" Width="72"
                                                  ItemTemplate="{StaticResource HotkeyOptionTemplate}" SelectedValuePath="Value"
                                                  SelectionChanged="HotkeyControl_OnChanged" />
                                    </StackPanel>
                                    <TextBlock x:Name="ShowDesktopHotkeyStatusText" HorizontalAlignment="Right"
                                               Margin="0,6,0,0" FontSize="11"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingRowStyle}" MinHeight="88">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="立即整理" FontWeight="SemiBold" />
                                    <TextBlock Text="按当前启用的规则整理桌面项目" Margin="0,5,0,0" FontSize="12"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <CheckBox x:Name="OrganizeHotkeyEnabledCheckBox"
                                                  Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,16,0"
                                                  Checked="HotkeyControl_OnChanged" Unchecked="HotkeyControl_OnChanged" />
                                        <ComboBox x:Name="OrganizeModifiersComboBox" Width="126"
                                                  ItemTemplate="{StaticResource HotkeyOptionTemplate}" SelectedValuePath="Value"
                                                  SelectionChanged="HotkeyControl_OnChanged" />
                                        <TextBlock Text="+" Margin="8,0" VerticalAlignment="Center" />
                                        <ComboBox x:Name="OrganizeKeyComboBox" Width="72"
                                                  ItemTemplate="{StaticResource HotkeyOptionTemplate}" SelectedValuePath="Value"
                                                  SelectionChanged="HotkeyControl_OnChanged" />
                                    </StackPanel>
                                    <TextBlock x:Name="OrganizeHotkeyStatusText" HorizontalAlignment="Right"
                                               Margin="0,6,0,0" FontSize="11"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Style="{StaticResource NavTabItemStyle}" AutomationProperties.Name="布局备份"
                     AutomationProperties.AutomationId="BackupTab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="28" />
                        <TextBlock Text="布局备份" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="44,36,48,38" MaxWidth="760">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="布局备份" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="保存和恢复盒子、规则与设置" Style="{StaticResource PageSubtitleStyle}" />
                        </StackPanel>
                        <Button x:Name="CreateBackupButton" Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}"
                                Width="112" Height="38" Content="立即备份"
                                AutomationProperties.Name="立即备份"
                                AutomationProperties.AutomationId="CreateBackupButton"
                                Click="CreateBackupButton_OnClick" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <TextBlock Text="每日自动备份" VerticalAlignment="Center" />
                                    <CheckBox x:Name="DailyBackupCheckBox" Style="{StaticResource ToggleSwitchStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="DailyBackupCheckBox_OnChanged"
                                              Unchecked="DailyBackupCheckBox_OnChanged" />
                                </Grid>
                            </Border>
                            <Border MinHeight="62">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="42" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="保留天数" VerticalAlignment="Center" />
                                    <Slider x:Name="BackupRetentionSlider" Grid.Column="1"
                                            Minimum="1" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="BackupRetentionSlider_OnValueChanged" />
                                    <TextBlock x:Name="BackupRetentionValueText" Grid.Column="2"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="备份目录" Style="{StaticResource SectionTitleStyle}" />
                            <Border Background="{DynamicResource SurfaceBackground}"
                                    BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                                    CornerRadius="7" Padding="12,10" Margin="0,0,0,12">
                                <TextBlock x:Name="BackupDirectoryText" TextWrapping="Wrap"
                                           FontSize="12" Foreground="{DynamicResource MutedTextBrush}" />
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="导出" Width="88" Margin="0,0,10,0" Click="ExportBackupButton_OnClick" />
                                <Button Content="导入" Width="88" Click="ImportBackupButton_OnClick" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="历史备份" Style="{StaticResource SectionTitleStyle}" />
                        <Border Grid.Row="2" Background="{DynamicResource SurfaceBackground}"
                                BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                                CornerRadius="8" Padding="8">
                            <ListBox x:Name="BackupList" AutomationProperties.Name="备份历史"
                                     AutomationProperties.AutomationId="BackupList">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Foreground="{DynamicResource MutedTextBrush}">
                                                <Run Text="{Binding BoxCount}" /><Run Text=" 个盒子" />
                                            </TextBlock>
                                            <TextBlock Grid.Column="2" Foreground="{DynamicResource MutedTextBrush}">
                                                <Run Text="{Binding RuleCount}" /><Run Text=" 条规则" />
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                        <Grid Grid.Row="3" Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="RestoreBackupButton" Content="恢复" Width="82" Margin="0,0,10,0"
                                        AutomationProperties.Name="恢复选中备份"
                                        AutomationProperties.AutomationId="RestoreBackupButton"
                                        Click="RestoreBackupButton_OnClick" />
                                <Button Content="删除" Width="82" Style="{StaticResource DangerButtonStyle}"
                                        Click="DeleteBackupButton_OnClick" />
                            </StackPanel>
                            <TextBlock x:Name="BackupStatusText" HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Style="{StaticResource NavTabItemStyle}" AutomationProperties.Name="整理规则">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8FD;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="28" />
                        <TextBlock Text="整理规则" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="34,30,38,32" MaxWidth="800">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="22" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="22" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="整理规则" Style="{StaticResource PageTitleStyle}" />
