<Window x:Class="CrabDesk.App.OrganizationPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="整理预览"
        Width="660"
        Height="480"
        MinWidth="560"
        MinHeight="400"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="整理预览" Style="{StaticResource PageTitleStyle}" />
            <TextBlock x:Name="SummaryText" Style="{StaticResource PageSubtitleStyle}" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="13,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="项目" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="规则" FontWeight="SemiBold" />
            <TextBlock Grid.Column="2" Text="结果" FontWeight="SemiBold" />
        </Grid>

        <Border Grid.Row="4" Background="{DynamicResource SurfaceBackground}"
                BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                CornerRadius="8" Padding="6">
            <ListBox x:Name="PreviewList">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="1.5*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding ItemName}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Text="{Binding RuleTitle}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Text="{Binding Result}"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Width="92" Margin="0,0,10,0" IsCancel="True" />
            <Button Content="应用整理" Width="104" Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True" Click="ApplyButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
