<Window x:Class="CrabDesk.App.OrganizationRuleEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="整理规则"
        Width="600"
        Height="620"
        MinWidth="540"
        MinHeight="560"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}">
    <Grid Margin="30,26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="整理规则" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="设置匹配条件和分组结果" Style="{StaticResource PageSubtitleStyle}" />
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="名称" VerticalAlignment="Center" />
                    <TextBox x:Name="TitleTextBox" Grid.Column="1" />
                </Grid>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="名称通配符" VerticalAlignment="Center" />
                    <TextBox x:Name="NamePatternTextBox" Grid.Column="1" />
                </Grid>
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="扩展名" VerticalAlignment="Center" />
                    <TextBox x:Name="ExtensionsTextBox" Grid.Column="1" />
                </Grid>

                <TextBlock Text="项目类型" Style="{StaticResource SectionTitleStyle}" />
                <WrapPanel Margin="0,0,0,22">
                    <CheckBox x:Name="FileKindCheckBox" Content="文件" Margin="0,0,22,0" />
                    <CheckBox x:Name="FolderKindCheckBox" Content="目录" Margin="0,0,22,0" />
                    <CheckBox x:Name="ShortcutKindCheckBox" Content="快捷方式" Margin="0,0,22,0" />
                    <CheckBox x:Name="ShellKindCheckBox" Content="系统项目" />
                </WrapPanel>

                <TextBlock Text="处理方式" Style="{StaticResource SectionTitleStyle}" />
                <Border HorizontalAlignment="Left" Padding="3" Margin="0,0,0,18"
                        CornerRadius="7" Background="{DynamicResource ControlBackground}"
                        BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="AssignActionRadioButton" Content="分配到盒子" Tag="AssignToBox"
                                     GroupName="RuleAction" Style="{StaticResource SegmentRadioStyle}"
                                     Checked="ActionRadioButton_OnChecked" />
                        <RadioButton x:Name="KeepActionRadioButton" Content="保持未分组" Tag="KeepUnassigned"
                                     GroupName="RuleAction" Style="{StaticResource SegmentRadioStyle}"
                                     Checked="ActionRadioButton_OnChecked" />
                        <RadioButton x:Name="IgnoreActionRadioButton" Content="忽略" Tag="Ignore"
                                     GroupName="RuleAction" Style="{StaticResource SegmentRadioStyle}"
                                     Checked="ActionRadioButton_OnChecked" />
                    </StackPanel>
                </Border>

                <TextBlock Text="目标盒子" Style="{StaticResource SectionTitleStyle}" />
                <Border Background="{DynamicResource SurfaceBackground}"
                        BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1"
                        CornerRadius="8" Padding="6" Margin="0,0,0,18">
                    <ListBox x:Name="TargetBoxesList" Height="104" DisplayMemberPath="Title" />
                </Border>

                <Grid MinHeight="52">
                    <TextBlock Text="启用规则" VerticalAlignment="Center" />
                    <CheckBox x:Name="EnabledCheckBox" Style="{StaticResource ToggleSwitchStyle}"
                              HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Width="92" Margin="0,0,10,0" IsCancel="True" />
            <Button Content="保存规则" Width="104" Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True" Click="SaveButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
