<Window
    x:Class="CrabDesk.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0,0,0">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Image Source="Assets/CrabDesk-256.png" Width="24" Height="24" />
                <TextBlock Text="CrabDesk" FontFamily="Segoe UI Variable Display"
                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="设置" Opacity="0.65"
                           FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <NavigationView x:Name="Navigation" Grid.Row="1"
                        PaneDisplayMode="LeftCompact"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="True"
                        OpenPaneLength="{StaticResource NavigationPaneWidth}"
                        CompactModeThresholdWidth="{StaticResource NavigationCompactThreshold}"
                        ExpandedModeThresholdWidth="{StaticResource NavigationExpandedThreshold}"
                        CompactPaneLength="48"
                        SizeChanged="Navigation_OnSizeChanged"
                        PaneOpening="Navigation_OnPaneOpening"
                        PaneClosing="Navigation_OnPaneClosing"
                        PaneOpened="Navigation_OnPaneChanged"
                        PaneClosed="Navigation_OnPaneChanged"
                        SelectionChanged="Navigation_OnSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="常规" Tag="general" AutomationProperties.Name="常规设置">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="快捷键" Tag="hotkeys" AutomationProperties.Name="全局快捷键">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Keyboard" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="布局备份" Tag="backup" AutomationProperties.Name="布局备份">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Save" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="整理规则" Tag="organization" AutomationProperties.Name="整理规则">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Filter" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="主题与外观" Tag="appearance" AutomationProperties.Name="主题与外观">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Edit" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="桌面盒子" Tag="boxes" AutomationProperties.Name="桌面盒子">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="ViewAll" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="关于" Tag="about" AutomationProperties.Name="关于 CrabDesk">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Help" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame"
                   MaxWidth="{StaticResource PageMaxWidth}"
                   Width="{StaticResource PageMaxWidth}"
                   HorizontalAlignment="Center"
                   HorizontalContentAlignment="Stretch" />
        </NavigationView>
    </Grid>
</Window>
