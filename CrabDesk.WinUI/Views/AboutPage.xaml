<Page
    x:Class="CrabDesk.WinUI.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:CrabDesk.Core"
    xmlns:icons="using:FluentIcons.WinUI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalContentAlignment="Stretch">
        <StackPanel Padding="{StaticResource PagePadding}"
                    HorizontalAlignment="Stretch" Spacing="24">
            <StackPanel>
                <TextBlock Text="关于" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="版本、更新、本地数据和桌面诊断" Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="16">
                <Image Source="/Assets/CrabDesk-256.png" Width="64" Height="64" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="CrabDesk" FontFamily="Segoe UI Variable Display" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding VersionText}" Foreground="{ThemeResource SecondaryTextBrush}" />
                </StackPanel>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="更新" Style="{StaticResource SectionTitleStyle}" />
                <Border Style="{StaticResource SectionCardStyle}" Padding="16,0">
                    <StackPanel>
                        <Border Style="{StaticResource SettingRowStyle}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="自动检查" FontWeight="SemiBold" />
                                    <TextBlock Text="CrabDesk 启动后检查所选通道的新版本" Style="{StaticResource SecondaryBodyStyle}" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" Style="{StaticResource CompactToggleSwitchStyle}" IsOn="{Binding CheckUpdatesOnStartup, Mode=TwoWay}"
                                              VerticalAlignment="Center" AutomationProperties.Name="启动时检查更新" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SettingRowStyle}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="发布通道" FontWeight="SemiBold" />
                                    <TextBlock Text="稳定版优先可靠性，预览版包含较新的功能" Style="{StaticResource SecondaryBodyStyle}" />
                                </StackPanel>
                                <ComboBox Grid.Column="1" Width="{StaticResource CompactSettingsControlWidth}"
                                          ItemsSource="{Binding UpdateChannels}"
                                          SelectedItem="{Binding UpdateChannel, Mode=TwoWay}"
                                          VerticalAlignment="Center" AutomationProperties.Name="更新通道" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SettingRowStyle}" BorderThickness="0">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="更新状态" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding UpdateStatus}" TextWrapping="Wrap" Style="{StaticResource SecondaryBodyStyle}" />
                                    <ProgressBar Margin="0,8,0,0" Width="280" HorizontalAlignment="Left"
                                                 Minimum="0" Maximum="100" Value="{Binding UpdateProgress}"
                                                 IsIndeterminate="{Binding IsUpdateProgressIndeterminate}"
                                                 Visibility="{Binding IsUpdateBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button Command="{Binding DownloadAndInstallUpdateCommand}"
                                            Visibility="{Binding CanDownloadUpdate, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Style="{StaticResource AccentButtonStyle}"
                                            ToolTipService.ToolTip="下载、验证并安装新版本">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <icons:FluentIcon Icon="ArrowDownload" />
                                            <TextBlock Text="下载并安装" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding OpenReleaseCommand}" IsEnabled="{Binding CanOpenRelease}"
                                            ToolTipService.ToolTip="查看发布页">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <icons:FluentIcon Icon="Open" />
                                            <TextBlock Text="发布页" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding CheckForUpdatesCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <icons:FluentIcon Icon="ArrowSync" />
                                            <TextBlock Text="检查更新" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="本地数据" Style="{StaticResource SectionTitleStyle}" />
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding ConfigDirectory}" Style="{StaticResource SecondaryBodyStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="打开配置目录" Command="{Binding OpenConfigDirectoryCommand}" />
                            <Button Content="清理图标缓存" Command="{Binding ClearCacheCommand}" />
                            <Button Content="复制诊断" Command="{Binding CopyDiagnosticsCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="维护" Style="{StaticResource SectionTitleStyle}" />
                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="重置桌面布局" />
                            <TextBlock Text="重建默认盒子，当前布局会先自动备份" Style="{StaticResource SecondaryBodyStyle}" />
                            <TextBlock Text="{Binding MaintenanceStatus}" Margin="0,8,0,0" Foreground="{ThemeResource AccentBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="重置布局" Command="{Binding ResetLayoutCommand}" />
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
