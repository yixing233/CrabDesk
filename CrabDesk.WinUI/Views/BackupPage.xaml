<Page
    x:Class="CrabDesk.WinUI.Views.BackupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:icons="using:FluentIcons.WinUI">
    <Grid Padding="{StaticResource PagePadding}" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="布局备份" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="创建、导入、导出和恢复桌面布局" Style="{StaticResource PageSubtitleStyle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource SectionCardStyle}" Padding="16,0" Margin="0,24,0,20">
            <StackPanel>
                <Border Style="{StaticResource SettingRowStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="备份位置" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding BackupDirectory}" Style="{StaticResource SecondaryBodyStyle}" />
                        </StackPanel>
                        <icons:FluentIcon Grid.Column="1" Icon="Folder" VerticalAlignment="Center"
                                          Foreground="{ThemeResource SecondaryTextBrush}" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource SettingRowStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="保留周期" FontWeight="SemiBold" />
                            <TextBlock Text="自动清理超过保留天数的历史备份" Style="{StaticResource SecondaryBodyStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <NumberBox Width="{StaticResource NumericSettingsControlWidth}" Minimum="1" Maximum="365" SpinButtonPlacementMode="Inline"
                                       Value="{Binding RetentionDays, Mode=TwoWay}" AutomationProperties.Name="备份保留天数" />
                            <TextBlock Text="天" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Style="{StaticResource SettingRowStyle}" BorderThickness="0">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="每日自动备份" FontWeight="SemiBold" />
                            <TextBlock Text="每天保留一份当前桌面布局快照" Style="{StaticResource SecondaryBodyStyle}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" Style="{StaticResource CompactToggleSwitchStyle}" IsOn="{Binding DailyBackup, Mode=TwoWay}"
                                      VerticalAlignment="Center" AutomationProperties.Name="每日自动备份" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" ColumnSpacing="12" Margin="0,0,0,8">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <TextBlock Text="备份记录" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" Margin="0" />
            <CommandBar Grid.Column="1" DefaultLabelPosition="Collapsed" Background="Transparent" HorizontalAlignment="Right">
                <AppBarButton Label="创建备份" Command="{Binding CreateCommand}" ToolTipService.ToolTip="创建备份"><AppBarButton.Icon><icons:FluentIcon Icon="Save" /></AppBarButton.Icon></AppBarButton>
                <AppBarButton Label="导出布局" Command="{Binding ExportCommand}" ToolTipService.ToolTip="导出布局"><AppBarButton.Icon><icons:FluentIcon Icon="SaveCopy" /></AppBarButton.Icon></AppBarButton>
                <AppBarButton Label="导入布局" Command="{Binding ImportCommand}" ToolTipService.ToolTip="导入布局"><AppBarButton.Icon><icons:FluentIcon Icon="DocumentArrowUp" /></AppBarButton.Icon></AppBarButton>
                <AppBarSeparator />
                <AppBarButton Label="恢复" Command="{Binding RestoreCommand}" ToolTipService.ToolTip="恢复所选备份"><AppBarButton.Icon><icons:FluentIcon Icon="History" /></AppBarButton.Icon></AppBarButton>
                <AppBarButton Label="删除" Command="{Binding DeleteCommand}" ToolTipService.ToolTip="删除所选备份"><AppBarButton.Icon><icons:FluentIcon Icon="Delete" /></AppBarButton.Icon></AppBarButton>
                <CommandBar.SecondaryCommands>
                    <AppBarButton Label="刷新" Command="{Binding RefreshCommand}" />
                </CommandBar.SecondaryCommands>
            </CommandBar>
        </Grid>

        <Grid Grid.Row="3">
            <ListView ItemsSource="{Binding Backups}" SelectedItem="{Binding SelectedBackup, Mode=TwoWay}"
                      SelectionMode="Single" Visibility="{Binding HasBackups, Converter={StaticResource BooleanToVisibilityConverter}}"
                      AutomationProperties.Name="布局备份列表">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8" ColumnSpacing="16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding CreatedAt}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Path}" Style="{StaticResource SecondaryBodyStyle}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding SchemaVersion}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="{Binding BoxCount}" />
                                <TextBlock Text="个盒子" Foreground="{ThemeResource SecondaryTextBrush}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Border Style="{StaticResource SectionCardStyle}" MinHeight="150"
                    Visibility="{Binding HasNoBackups, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <icons:FluentIcon Icon="Save" FontSize="28" Foreground="{ThemeResource SecondaryTextBrush}" />
                    <TextBlock Text="还没有布局备份" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="创建备份后，可随时恢复当前桌面布局" Style="{StaticResource SecondaryBodyStyle}" />
                </StackPanel>
            </Border>
        </Grid>
        <TextBlock Grid.Row="4" Text="{Binding Status}" Margin="0,10,0,0" Foreground="{ThemeResource AccentBrush}" />
    </Grid>
</Page>
