<Application
    x:Class="CrabDesk.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CrabDesk.WinUI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Resources/ThemeResources.xaml" />
                <ResourceDictionary Source="Resources/DesignTokens.xaml" />
                <ResourceDictionary Source="Resources/ControlStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:HexColorConverter x:Key="HexColorConverter" />
            <converters:HexBrushConverter x:Key="HexBrushConverter" />
            <DataTemplate x:Key="FontFamilyItemTemplate">
                <TextBlock Text="{Binding}" FontFamily="{Binding}" />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
